{
  "$schema": "./node_modules/nx/schemas/nx-schema.json",
  "tui": {
    "autoExit": true
  },
  "namedInputs": {
    "default": [
      "{projectRoot}/**/*",
      "sharedGlobals"
    ],
    "production": [
      "default",
      "!{projectRoot}/**/?(*.)+(spec|test).[jt]s?(x)?(.snap)",
      "!{projectRoot}/tsconfig.spec.json",
      "!{projectRoot}/vitest.config.ts"
    ],
    "sharedGlobals": [
      "{workspaceRoot}/biome.json",
      "{workspaceRoot}/prisma/schema.prisma"
    ]
  },
  "targetDefaults": {
    "typecheck": {
      "cache": true,
      "dependsOn": [
        "^build",
        "^typecheck"
      ],
      "inputs": [
        "default",
        "^default",
        "{workspaceRoot}/tsconfig.base.json",
        "{projectRoot}/tsconfig.json"
      ]
    },
    "build": {
      "dependsOn": [
        "^build"
      ],
      "inputs": [
        "production",
        "^production"
      ],
      "cache": true
    },
    "test": {
      "executor": "nx:run-commands",
      "options": {
        "command": "vitest run --config {projectRoot}/vitest.config.ts"
      },
      "inputs": [
        "default",
        "^production"
      ],
      "cache": true
    },
    "lint": {
      "executor": "nx:run-commands",
      "options": {
        "command": "biome check {projectRoot}/src"
      },
      "inputs": [
        "default",
        "{workspaceRoot}/biome.json"
      ],
      "cache": true
    },
    "db:migrate": {
      "dependsOn": [
        "db:generate"
      ],
      "cache": false
    }
  },
  "plugins": [
    {
      "plugin": "@nx/docker",
      "options": {
        "buildTarget": {
          "name": "docker:build"
        },
        "runTarget": {
          "name": "docker:run"
        }
      }
    }
  ],
  "defaultBase": "main",
  "analytics": false,
  "useInferencePlugins": true,
  "neverConnectToCloud": true
}
