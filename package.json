{
  "name": "agrario",
  "version": "0.1.0",
  "description": "",
  "type": "module",
  "private": true,
  "scripts": {
    "prepare": "husky",
    "lint": "nx run-many -t lint --all",
    "lint:affected": "nx affected -t lint",
    "lint:fix": "nx affected -t lint --fix",
    "test": "nx run-many -t test --all",
    "test:affected": "nx affected -t test",
    "test:coverage": "nx affected -t test -- --coverage",
    "format": "npx biome check --write .",
    "format:check": "npx biome check .",
    "ci:quality": "pnpm lint:affected && pnpm test:affected",
    "db:generate": "prisma generate",
    "db:migrate": "prisma migrate dev",
    "db:reset-force": "prisma db push --force-reset",
    "pretypecheck": "prisma generate",
    "typecheck:all": "nx run-many --target=typecheck --all",
    "typecheck:affected": "nx affected --target=typecheck"
  },
  "keywords": [
    "agroculture",
    "farm",
    "management",
    "software"
  ],
  "license": "BSD-3-Clause",
  "packageManager": "pnpm@10.33.0",
  "devDependencies": {
    "@nx/docker": "22.6.5",
    "@prisma/adapter-pg": "^7.7.0",
    "@prisma/client": "^7.7.0",
    "@types/node": "^25.6.0",
    "dotenv": "^17.4.2",
    "husky": "^9.1.7",
    "nx": "22.6.5",
    "pg": "^8.20.0",
    "prisma": "^7.7.0",
    "typescript": "^6.0.3",
    "vitest": "^4.1.4"
  },
  "nx": {},
  "engines": {
    "node": "24.1.0"
  }
}
