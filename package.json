{
  "name": "agrario",
  "version": "0.1.0",
  "type": "module",
  "private": true,
  "license": "BSD-3-Clause",
  "scripts": {
    "prepare": "husky",
    "lint:all": "nx run-many -t lint --all",
    "lint:affected": "nx affected -t lint",
    "lint:fix": "nx affected -t lint --fix",
    "test:all": "nx run-many -t test --all",
    "test:affected": "nx affected -t test",
    "test:coverage": "nx affected -t test -- --coverage",
    "format:all": "nx run-many -t format --all",
    "format:affected": "nx affected -t format",
    "ci:quality": "pnpm lint:affected && pnpm test:affected",
    "db:generate": "prisma generate",
    "db:migrate": "prisma migrate dev",
    "db:reset-force": "./scripts/prisma-complete-clear.sh",
    "pretypecheck": "prisma generate",
    "typecheck:all": "nx run-many --target=typecheck --all",
    "typecheck:affected": "nx affected --target=typecheck"
  },
  "keywords": [
    "agroculture",
    "farming",
    "management",
    "software"
  ],
  "packageManager": "pnpm@11.0.9",
  "devDependencies": {
    "@nx/docker": "catalog:nx",
    "@nx/js": "catalog:nx",
    "@nx/storybook": "catalog:nx",
    "@nx/vite": "catalog:nx",
    "@nx/web": "catalog:nx",
    "@prisma/client": "catalog:",
    "@storybook/react": "catalog:storybook",
    "@storybook/react-vite": "catalog:storybook",
    "@swc-node/register": "catalog:",
    "@swc/core": "catalog:",
    "@swc/helpers": "catalog:",
    "husky": "catalog:",
    "nx": "catalog:",
    "oxfmt": "catalog:",
    "oxlint": "catalog:",
    "prisma": "catalog:",
    "prisma-class-generator": "catalog:",
    "prisma-generator-express": "catalog:",
    "prisma-generator-plantuml-erd": "catalog:",
    "ts-node": "catalog:",
    "tslib": "catalog:",
    "typescript": "catalog:"
  },
  "nx": {},
  "engines": {
    "node": ">=25.x.x <27"
  }
}