{
  "name": "agrario",
  "version": "0.1.0",
  "type": "module",
  "private": true,
  "scripts": {
    "prepare": "husky",
    "lint:all": "nx run-many -t lint --all",
    "lint:affected": "nx affected -t lint",
    "lint:fix": "nx affected -t lint --fix",
    "test:all": "nx run-many -t test --all",
    "test:affected": "nx affected -t test",
    "test:coverage": "nx affected -t test -- --coverage",
    "ci:quality": "pnpm lint:affected && pnpm test:affected",
    "db:generate": "prisma generate",
    "db:migrate": "prisma migrate dev",
    "db:reset-force": "./scripts/prisma-complete-clear.sh",
    "pretypecheck": "prisma generate",
    "typecheck:all": "nx run-many --target=typecheck --all",
    "typecheck:affected": "nx affected --target=typecheck"
  },
  "keywords": [
    "agroculture",
    "farm",
    "management",
    "software"
  ],
  "dependencies": {
    "@vitejs/plugin-react": "6.0.1",
    "express": "^5.2.1"
  },
  "license": "BSD-3-Clause",
  "packageManager": "pnpm@10.33.0",
  "devDependencies": {
    "@nx/docker": "22.6.5",
    "@nx/js": "22.6.5",
    "@nx/storybook": "22.6.5",
    "@nx/vite": "22.6.5",
    "@nx/web": "22.6.5",
    "@prisma/adapter-pg": "^7.7.0",
    "@prisma/client": "^7.8.0",
    "@storybook/react": "10.3.6",
    "@storybook/react-vite": "10.3.6",
    "@swc-node/register": "~1.11.1",
    "@swc/core": "~1.15.5",
    "@swc/helpers": "~0.5.18",
    "@types/node": "^25.6.0",
    "dotenv": "^17.4.2",
    "husky": "^9.1.7",
    "nx": "22.6.5",
    "oxfmt": "0.47.0",
    "oxlint": "1.62.0",
    "pg": "^8.20.0",
    "prettier": "~3.6.2",
    "prisma": "^7.8.0",
    "prisma-generator-express": "1.35.0",
    "prisma-generator-plantuml-erd": "1.7.1",
    "storybook": "10.3.6",
    "ts-node": "10.9.1",
    "tslib": "^2.3.0",
    "typescript": "^6.0.3",
    "vite": "^6.0.0",
    "vitest": "^4.1.4"
  },
  "nx": {},
  "engines": {
    "node": ">=25.9.0"
  }
}
