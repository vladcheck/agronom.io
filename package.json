{
  "name": "agrario",
  "version": "0.1.0",
  "type": "module",
  "private": true,
  "scripts": {
    "prepare": "husky",
    "lint:all": "nx run-many -t lint --all",
    "lint:affected": "nx affected -t lint",
    "lint:fix": "nx affected -t lint --fix",
    "test:all": "nx run-many -t test --all",
    "test:affected": "nx affected -t test",
    "test:coverage": "nx affected -t test -- --coverage",
    "ci:quality": "pnpm lint:affected && pnpm test:affected",
    "db:generate": "prisma generate",
    "db:migrate": "prisma migrate dev",
    "db:reset-force": "./scripts/prisma-complete-clear.sh",
    "pretypecheck": "prisma generate",
    "typecheck:all": "nx run-many --target=typecheck --all",
    "typecheck:affected": "nx affected --target=typecheck"
  },
  "keywords": [
    "agroculture",
    "farm",
    "management",
    "software"
  ],
  "dependencies": {
    "express": "^5.2.1"
  },
  "license": "BSD-3-Clause",
  "packageManager": "pnpm@10.33.0",
  "devDependencies": {
    "@nx/docker": "22.6.5",
    "@prisma/adapter-pg": "^7.7.0",
    "@prisma/client": "^7.8.0",
    "@types/node": "^25.6.0",
    "dotenv": "^17.4.2",
    "husky": "^9.1.7",
    "nx": "22.6.5",
    "oxfmt": "0.47.0",
    "oxlint": "1.62.0",
    "pg": "^8.20.0",
    "prisma": "^7.8.0",
    "prisma-generator-express": "1.35.0",
    "prisma-generator-plantuml-erd": "1.7.1",
    "typescript": "^6.0.3",
    "vitest": "^4.1.4"
  },
  "nx": {},
  "engines": {
    "node": ">=25.9.0"
  }
}
